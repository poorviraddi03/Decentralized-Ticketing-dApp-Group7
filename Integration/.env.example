# .env.example — copy to .env and fill in your values
# NEVER commit your actual .env to GitHub

# Your wallet private key (for Amoy testnet deployment)
# Export from MetaMask: Account Details → Export Private Key
PRIVATE_KEY=0xyour_private_key_here

# Polygonscan API key (for contract verification — optional)
# Get at https://polygonscan.com/myapikey
POLYGONSCAN_KEY=your_polygonscan_api_key_here

# Set to "true" to enable gas cost reporting in tests
REPORT_GAS=false
