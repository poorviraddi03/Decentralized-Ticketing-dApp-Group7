# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Your wallet private key (no 0x prefix needed by some tools — check your setup)
PRIVATE_KEY=your_private_key_here

# Polygon Amoy testnet RPC URL (get a free one from Alchemy or Infura)
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your_api_key_here

# Polygonscan API key for contract verification (optional)
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
